# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit real tokens.

# HuggingFace token. Required ONLY for the initial model download
# (pyannote diarization is a gated model). Not needed at runtime.
# Generate at https://hf.co/settings/tokens — must accept the
# pyannote/speaker-diarization-community-1 license first.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Inference device: "cuda" or "cpu"
DEVICE=cuda

# CTranslate2 compute type: float16 (cuda recommended), int8_float16, int8 (cpu)
COMPUTE_TYPE=float16

# Default whisper model when /transcribe is called without a "model" param.
# One of: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=small

# API server bind address & port
API_HOST=0.0.0.0
API_PORT=8000
